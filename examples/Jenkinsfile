/* =========================
 * Jenkins MR Automation — Main Webhook Pipeline
 * Uses the recursiveCreateAndTrigger plugin step
 * ========================= */

// repoPath 기준 skip regex 목록
def SKIP_PATTERNS = '.*/(experimental|deprecated)/.*'

pipeline {
    agent none

    stages {
        stage('Create and Trigger') {
            steps {
                script {
                    def sshUrl = env.gitlabTargetRepoSshUrl
                    def matcher = (sshUrl =~ /git@[\w.]+:(.*)\.git/)
                    if (!matcher) {
                        error("Cannot parse gitlabTargetRepoSshUrl: ${sshUrl}")
                    }
                    def repoPath = matcher[0][1]

                    recursiveCreateAndTrigger(
                        repoPath: repoPath,
                        defaultTemplate: 'MergeRequests/Template',
                        defaultTargetName: '${REPO}/merge_request',
                        skipPattern: SKIP_PATTERNS,
                        configuration: [
                            templateRule(
                                pattern: '.*abel/ip.*',
                                finalJobNamePattern: '${REPO}/ip-mr',
                                templateName: 'bos_soc_design/abel/ip/MergeRequestTemplate'
                            )
                        ]
                    )
                }
            }
        }
    }
}
